{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["syd1"],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "functions": {
    "app/api/screener/route.ts": {
      "maxDuration": 30
    },
    "app/api/snapshot/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/check-alerts/route.ts": {
      "maxDuration": 120
    }
  }
}